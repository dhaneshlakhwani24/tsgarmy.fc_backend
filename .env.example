PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/tsgarmy
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Comma-separated additional origins for production frontend/admin domains
CORS_EXTRA_ORIGINS=

# Express / proxy setup (set to 1 behind a load balancer)
TRUST_PROXY=1

# API limits (requests per minute per IP)
RATE_LIMIT_READ_RPM=1500
RATE_LIMIT_WRITE_RPM=300

# JSON request body limit
JSON_BODY_LIMIT=1mb

# Compression level (1-9)
COMPRESSION_LEVEL=6

# MongoDB pool tuning
MONGO_MAX_POOL_SIZE=300
MONGO_MIN_POOL_SIZE=20
MONGO_MAX_IDLE_MS=60000
MONGO_SERVER_SELECTION_TIMEOUT_MS=8000
MONGO_SOCKET_TIMEOUT_MS=45000

# Max concurrent SSE clients accepted by one backend instance
SSE_MAX_CLIENTS=20000

# Admin auth
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=12h
SUPER_ADMIN_USERNAME=dhaneshlakhwani
SUPER_ADMIN_PASSWORD=dhanesh@24
